APP_NAME=SoloLedger API
APP_ENV=development
DATABASE_URL=postgresql://postgres:password@localhost:5432/sololedger
API_V1_PREFIX=/api/v1
SUPABASE_JWT_SECRET=replace-me
SUPABASE_AUDIENCE=authenticated
ALLOW_DEV_AUTH=true
AUTH_JWT_SECRET=replace-me
AUTH_PASSWORD_SECRET=replace-me
AUTH_ACCESS_TOKEN_EXPIRY_MINUTES=60
AUTH_REFRESH_TOKEN_EXPIRY_DAYS=7
AUTH_REFRESH_COOKIE_NAME=sololedger_refresh_token
AUTH_COOKIE_SECURE=false
AZURE_API_KEY=replace-me
AZURE_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-mini
AZURE_OPENAI_MODEL=gpt-4.1-mini
AZURE_OPENAI_API_VERSION=2024-12-01-preview
FRONTEND_BASE_URL=http://localhost:8080
OAUTH_STATE_SECRET=replace-me
TOKEN_ENCRYPTION_SECRET=replace-me
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/mail/gmail/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:8000/api/v1/mail/outlook/callback
SMTP_API_KEY=
SMTP_FROM_EMAIL=onboarding@resend.dev
